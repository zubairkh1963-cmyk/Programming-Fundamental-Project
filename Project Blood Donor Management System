void update()
{
    int ID, option;
    bool found = false;
    int index;
    cout << "Enter ID of donor to update info";
    cin >> ID;
    for (int i = 0; i < count; i++)
    {
        if (donors[i].donorID == ID)
        {
            found=true;
            index = i;
            break;
        }
    }
    if (found == false)
    {
        cout<<"\nNo ID Found "<<endl;
        return;
    }
    else
	{
    cout << "\nChoose what to update: " << endl;
    cout << "1. Contact number" << endl;
    cout << "2. Last donation date" << endl;
    cin >> option;
    cin.ignore();
    switch (option)
    {
        case 1:
        {
            string newNumber;
            bool valid;
            do
            {
                valid = true;
                cout << "Enter new contact number: ";
                getline(cin, newNumber);
                if (newNumber.length() != 11)
                {
                    cout << "Invalid number length" << endl;
                    valid = false;
                    continue;
                }
                for (int i = 0; i < count; i++)
                {
                    if (i != index && donors[i].contactNumber == newNumber)
                    {
                        cout << "This contact number already exists." << endl;
                        valid = false;
                        break;
                    }
                }
            } while (!valid);
            donors[index].contactNumber = newNumber;
            cout << "Contact number updated successfully." << endl;
            break;
        }
        case 2:
        {
            cout << "\nEnter new donation date : ";
            getline(cin, donors[index].donationDate);
            break;
        }
        default:
            cout << "Invalid option";
    }
	}
}
void deletedonor()
{
    int ID, index;
    bool found = 0;
    cout << "Enter ID to delete : " << endl;
    cin >> ID;
    for (int i=0; i<count; i++)
    {
        if (ID == donors[i].donorID)
        {
            found = 1;
            index = i;
            break;
        }
    }
    if (found == 1)
    {
        for (int i = index; i < count - 1; i++)
        {
            donors[i].name = donors[i + 1].name;
            donors[i].age = donors[i + 1].age;
            donors[i].gender = donors[i + 1].gender;
            donors[i].city = donors[i + 1].city;
            donors[i].donationDate = donors[i + 1].donationDate;
            donors[i].contactNumber = donors[i + 1].contactNumber;
            donors[i].bloodgroup = donors[i + 1].bloodgroup;
            donors[i].donorID=donors[i+1].donorID;
        }
        cout<<"\nRecord deleted successfully. "<< endl;
        count--;
    }
    else
    {
        cout<<"Record not found "<<endl;
        return;
    }
}
